# URL di connessione al database PostgreSQL (usata a runtime dall'app).
# In locale (Docker): postgresql://loqo:loqo@localhost:5432/loqo?schema=public
# In produzione (Neon): usa la connection string "pooled" (pgbouncer),
# aggiungendo `&pgbouncer=true&connection_limit=5` per evitare di esaurire il
# pool di connessioni lato Prisma quando si passa dietro PgBouncer.
DATABASE_URL="postgresql://loqo:loqo@localhost:5432/loqo?schema=public"

# URL di connessione diretta (non pooled), usata da Prisma per le migration.
# In locale (Docker) può essere identica a DATABASE_URL.
# Su Neon: usa la connection string diretta (senza "-pooler" nell'host).
DIRECT_URL="postgresql://loqo:loqo@localhost:5432/loqo?schema=public"

# Segreto usato da Auth.js (NextAuth v5) per firmare i JWT di sessione.
# Obbligatorio: senza questo valore auth() lancia MissingSecret e
# l'autenticazione si comporta in modo imprevedibile (vedi README).
# Genera un valore casuale con: npx auth secret
# oppure: openssl rand -base64 33
AUTH_SECRET="changeme"

# URL base dell'applicazione, deve puntare al dominio reale in produzione
# (es. https://utilyno.it). Richiesta da Auth.js per costruire correttamente
# redirect e cookie di sessione.
AUTH_URL="http://localhost:3000"

# Token di accesso al Vercel Blob Store, usato da @vercel/blob per upload,
# download ed eliminazione dei documenti (vedi app/api/documenti/**).
# In produzione su Vercel viene iniettato automaticamente se il progetto ha
# uno Storage Blob collegato. In locale va generato manualmente da:
# Vercel Dashboard > Storage > Blob > Connect/Create > .env.local tab
# (oppure `vercel env pull` se il progetto è già collegato).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
