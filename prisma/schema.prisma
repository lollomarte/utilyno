generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum Role {
  ADMIN
  AGENZIA
  AMMINISTRATORE
  /// Proprietario e Inquilino non sono più ruoli-account separati: un utente PRIVATO ha un
  /// unico profilo Privato, e il ruolo PROPRIETARIO/INQUILINO vive per-immobile su
  /// RelazioneImmobilePrivato, non più sull'account. Vedi requirePrivato().
  PRIVATO
}

enum TipoSoggetto {
  PERSONA_FISICA
  AZIENDA
}

enum RuoloRelazioneImmobile {
  PROPRIETARIO
  INQUILINO
}

/// IN_ATTESA: relazione non ancora confermata (es. richiesta di collegamento immobile in corso).
/// ATTIVA: relazione corrente e valida.
/// CESSATA: relazione conclusa (es. era inquilino, ora è uscito) — mantenuta come storico.
enum StatoRelazioneImmobile {
  ATTIVA
  CESSATA
  IN_ATTESA
}

enum TipoImmobile {
  RESIDENZIALE
  COMMERCIALE
}

enum CondizioneImmobile {
  NUOVO
  RISTRUTTURATO
  DA_RISTRUTTURARE
}

enum TipoRiscaldamento {
  AUTONOMO
  CENTRALIZZATO
}

enum CategoriaDocumento {
  CONTRATTO
  APE
  PLANIMETRIA
  CARTA_IDENTITA
  VISURA_CATASTALE
  POLIZZA
  ALTRO
}

enum TipoNotaSviluppatore {
  BUG
  SUGGERIMENTO
}

/// BOZZA_PROPRIETARIO: auto-inserito dal Proprietario, nessuna agenzia ancora assegnata.
/// IN_GESTIONE_AGENZIA: un'Agenzia ha accettato la richiesta di gestione (vedi RichiestaGestioneImmobile).
/// ATTIVO: creato direttamente da Agenzia o Amministratore (flusso preesistente, agenzia già presente dalla creazione).
enum StatoImmobile {
  BOZZA_PROPRIETARIO
  IN_GESTIONE_AGENZIA
  ATTIVO
}

enum StatoRichiestaGestione {
  IN_ATTESA
  ACCETTATA
  RIFIUTATA
}

enum TipoContratto {
  QUATTRO_PIU_QUATTRO
  TRE_PIU_DUE
  TRANSITORIO
  STUDENTI
  CONCORDATO
}

enum RegimeFiscale {
  CEDOLARE_SECCA
  ORDINARIO
}

enum StatoContratto {
  BOZZA
  ATTIVO
  SCADUTO
  RISOLTO
}

enum StatoDeposito {
  NON_VERSATO
  VERSATO
  IN_CONTESTAZIONE
  RESTITUITO
}

enum StatoPagamento {
  PROGRAMMATO
  PAGATO
  IN_RITARDO
  INSOLUTO
}

enum TipoUtenza {
  LUCE
  GAS
  ACQUA
  INTERNET
}

enum StatoUtenza {
  DA_ATTIVARE
  ATTIVA
  DISDETTA
}

enum StatoAssicurazione {
  ATTIVA
  SCADUTA
  DA_RINNOVARE
}

enum TipoChecklist {
  INGRESSO
  USCITA
}

enum StatoSegnalazione {
  APERTA
  IN_LAVORAZIONE
  RISOLTA
}

enum CategoriaSegnalazione {
  PROBLEMA_UNITA
  PROBLEMA_CONDOMINIALE
  PROBLEMA_MISTO
  PROBLEMA_CONTRATTUALE
}

/**
 * Categoria dell'intervento necessario: asse indipendente dalla categoria di routing sopra.
 * Usata sia per classificare i Partner sia (opzionalmente) una Segnalazione, per il matching lead->partner.
 */
enum CategoriaIntervento {
  IDRAULICO
  ELETTRICISTA
  CALDAIA_CLIMATIZZAZIONE
  MANUTENZIONE_GENERICA
  UTENZE_LUCE_GAS
  ASSICURAZIONE
  ALTRO
}

enum StatoRichiestaPreventivo {
  INVIATA
  CONTATTATO
  PREVENTIVO_RICEVUTO
  CHIUSA_CONVERTITA
  CHIUSA_NON_CONVERTITA
}

// ---------- Models ----------

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  passwordHash   String
  role           Role
  nome           String
  cognome        String
  telefono       String?
  createdAt      DateTime  @default(now())
  /// Valorizzato quando l'account viene anonimizzato da un Admin (GDPR): nome/cognome/email/
  /// telefono sono già stati sostituiti con placeholder. Righe storiche (contratti, pagamenti,
  /// log) restano intatte, solo i dati personali diretti sull'utente vengono rimossi.
  anonimizzatoAt DateTime?

  agenzia              Agenzia?
  amministratore       Amministratore?
  privato              Privato?
  letture              LetturaComunicazione[]
  segnalazioniCreate   Segnalazione[]             @relation("SegnalazioniCreate")
  segnalazioniRicevute SegnalazioneDestinatario[]
  segnalazioniRisposte SegnalazioneRisposta[]
  richiestePreventivo  RichiestaPreventivo[]
  documentiCaricati    Documento[]                @relation("DocumentiCaricati")
  documentiCondivisi   DocumentoCondivisione[]
  noteSviluppatore     NotaSviluppatore[]
}

/// Storico dei tentativi di login (falliti e riusciti), usato per il blocco temporaneo
/// dopo troppi tentativi falliti consecutivi sulla stessa email. Persistito su DB (non
/// in memoria) perché l'app gira su funzioni serverless: un contatore in-process non
/// sopravvive tra invocazioni/istanze diverse e sarebbe banale da aggirare.
model TentativoLogin {
  id        String   @id @default(cuid())
  email     String
  esito     Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

/// Log minimo delle scritture su entità sensibili (Contratto, Pagamento, Deposito,
/// Documento, ...): chi ha fatto cosa e quando. Niente FK verso User: un log deve
/// restare leggibile anche se l'utente viene poi anonimizzato (vedi anonimizzazione
/// account), e non deve mai bloccare la scrittura dell'entità che accompagna.
model LogAzione {
  id        String   @id @default(cuid())
  userId    String
  azione    String
  entita    String
  entitaId  String
  note      String?
  createdAt DateTime @default(now())

  @@index([entita, entitaId])
  @@index([userId])
  @@index([createdAt])
}

model Agenzia {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ragioneSociale String
  piva           String  @unique
  indirizzo      String
  telefono       String?
  /// PEC per comunicazioni legali/RLI: opzionale, compilabile anche dopo la registrazione.
  pec            String?
  /// Codice destinatario SDI per fatturazione elettronica.
  codiceSdi      String?
  ibanAgenzia    String?

  immobili          Immobile[]
  contratti         Contratto[]
  richiesteGestione RichiestaGestioneImmobile[]
}

model Amministratore {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  ragioneSociale String
  piva           String  @unique
  indirizzo      String
  telefono       String?
  pec            String?
  codiceSdi      String?

  condomini Condominio[]
}

model Condominio {
  id               String         @id @default(cuid())
  amministratoreId String
  amministratore   Amministratore @relation(fields: [amministratoreId], references: [id], onDelete: Cascade)

  nome        String
  indirizzo   String
  comune      String
  numeroUnita Int
  createdAt   DateTime @default(now())

  /// Codice fiscale del condominio (distinto dalla P.IVA dell'Amministratore): richiesto per la polizza globale fabbricato.
  codiceFiscale   String?
  ibanCondominio  String?
  annoCostruzione Int?
  ascensore       Boolean?
  /// Impianti comuni rilevanti per la polizza (es. autoclave, riscaldamento centralizzato, cancello automatico).
  impiantiComuni  String[] @default([])

  immobili      Immobile[]
  comunicazioni ComunicazioneCondominiale[]
  documenti     Documento[]

  @@index([amministratoreId])
}

/// Attore unificato per "privati" (ex Proprietario/Inquilino): un solo profilo per persona,
/// collegato a User come Agenzia/Amministratore. Il ruolo PROPRIETARIO/INQUILINO non è più un
/// attributo dell'account ma vive per-immobile su RelazioneImmobilePrivato — la stessa persona
/// può essere proprietaria di un immobile e inquilina di un altro, o anche entrambe le cose nel
/// tempo sullo stesso immobile.
///
/// Modello unico (non subclassato): i campi specifici di AZIENDA restano nullable e la
/// validazione condizionale in base a `tipoSoggetto` vive lato applicativo (Zod), non come
/// constraint DB rigidi, per restare flessibile.
model Privato {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tipoSoggetto TipoSoggetto

  /// PERSONA_FISICA: codice fiscale personale. AZIENDA: codice fiscale dell'azienda (in Italia
  /// numericamente coincide quasi sempre con la partita IVA, ma resta un campo esplicito
  /// invece di essere dedotto da `piva`, per restare corretto anche nei rari casi in cui differisce).
  codiceFiscale String? @unique

  // --- Solo per tipoSoggetto = AZIENDA ---
  ragioneSociale String?
  piva           String? @unique
  /// Nome del referente/firmatario per conto dell'azienda.
  referenteNome  String?
  /// Ruolo del referente (es. "Amministratore delegato", "Procuratore").
  referenteRuolo String?

  indirizzo String?
  /// Per accredito canoni/deposito quando questo Privato ha relazioni PROPRIETARIO su uno o
  /// più immobili: vive qui (non su Immobile/RelazioneImmobilePrivato) perché lo stesso IBAN
  /// vale per tutti gli immobili di cui è proprietario.
  iban      String?

  relazioniImmobile         RelazioneImmobilePrivato[]
  richiesteGestione         RichiestaGestioneImmobile[]
  inviti                    InvitoInquilino[]
  contrattiComeProprietario Contratto[]                 @relation("ContrattoProprietario")
  contrattiComeInquilino    Contratto[]                 @relation("ContrattoInquilino")
}

/// Relazione N:N tra Privato e Immobile: il ruolo (PROPRIETARIO/INQUILINO) è specifico per
/// ogni singola relazione, non per l'account. Un privato può avere più relazioni con lo stesso
/// immobile nel tempo (es. era inquilino, ora è uscito): nessun vincolo di unicità stretto,
/// solo un indice per le query più comuni (relazioni attive di un privato per ruolo).
model RelazioneImmobilePrivato {
  id String @id @default(cuid())

  privatoId  String
  privato    Privato  @relation(fields: [privatoId], references: [id], onDelete: Cascade)
  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)

  ruolo RuoloRelazioneImmobile
  stato StatoRelazioneImmobile @default(ATTIVA)

  /// Valorizzato quando la relazione nasce da un Contratto attivo (sempre per INQUILINO; per
  /// PROPRIETARIO può restare null se l'immobile non è ancora sotto contratto, es. BOZZA_PROPRIETARIO).
  contrattoId String?
  contratto   Contratto? @relation(fields: [contrattoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([privatoId, immobileId, ruolo, stato])
}

model Immobile {
  id           String      @id @default(cuid())
  agenziaId    String?
  agenzia      Agenzia?    @relation(fields: [agenziaId], references: [id], onDelete: Cascade)
  condominioId String?
  condominio   Condominio? @relation(fields: [condominioId], references: [id], onDelete: SetNull)

  indirizzo     String
  comune        String
  provincia     String
  datiCatastali String
  superficieMq  Float
  tipoImmobile  TipoImmobile
  apeClasse     String?
  valoreStimato Float
  stato         StatoImmobile @default(BOZZA_PROPRIETARIO)
  createdAt     DateTime      @default(now())

  // ---- Dati aggiuntivi opzionali: non richiesti per l'uso attuale della piattaforma, ma
  // servono a valle (passaggio in gestione ad agenzia, RLI, quotazione assicurativa, ecc.)
  // senza dover richiedere di nuovo gli stessi dati in un secondo momento.
  foglio                   String?
  particella               String?
  subalterno               String?
  categoriaCatastale       String?
  renditaCatastale         Float?
  apeScadenza              DateTime?
  numeroVani               Int?
  piano                    String?
  ascensore                Boolean?
  annoCostruzione          Int?
  condizioneImmobile       CondizioneImmobile?
  arredato                 Boolean?
  /// Dotazioni libere (es. climatizzazione, cantina, box auto) — stesso pattern di fotoUrls su ChecklistImmobile.
  dotazioni                String[]            @default([])
  tipoRiscaldamento        TipoRiscaldamento?
  speseCondominialiMensili Float?
  noteStima                String?

  contratti         Contratto[]
  utenze            Utenza[]
  assicurazioni     Assicurazione[]
  documenti         Documento[]
  segnalazioni      Segnalazione[]
  richiesteGestione RichiestaGestioneImmobile[]
  relazioni         RelazioneImmobilePrivato[]

  @@index([agenziaId])
  @@index([condominioId])
  @@index([stato])
}

/// Richiesta del Proprietario a un'Agenzia esistente per prendere in gestione un Immobile
/// auto-inserito (stato BOZZA_PROPRIETARIO): stesso pattern di RichiestaPreventivo.
model RichiestaGestioneImmobile {
  id String @id @default(cuid())

  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)

  proprietarioId String
  proprietario   Privato @relation(fields: [proprietarioId], references: [id], onDelete: Cascade)

  agenziaId String
  agenzia   Agenzia @relation(fields: [agenziaId], references: [id], onDelete: Cascade)

  stato         StatoRichiestaGestione @default(IN_ATTESA)
  messaggio     String?
  dataRichiesta DateTime               @default(now())
  dataRisposta  DateTime?

  @@index([immobileId])
  @@index([proprietarioId])
  @@index([agenziaId])
  @@index([stato])
}

model Contratto {
  id             String   @id @default(cuid())
  immobileId     String
  immobile       Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)
  /// Chi era proprietario dell'immobile al momento del contratto: esplicito qui (non derivato
  /// da Immobile, che non ha più un proprietario diretto) perché la titolarità può cambiare nel
  /// tempo mentre il contratto storico deve continuare a riflettere chi lo era allora.
  proprietarioId String
  proprietario   Privato  @relation("ContrattoProprietario", fields: [proprietarioId], references: [id], onDelete: Cascade)
  inquilinoId    String
  inquilino      Privato  @relation("ContrattoInquilino", fields: [inquilinoId], references: [id], onDelete: Cascade)
  agenziaId      String
  agenzia        Agenzia  @relation(fields: [agenziaId], references: [id], onDelete: Cascade)

  tipoContratto                  TipoContratto
  dataInizio                     DateTime
  dataFine                       DateTime
  canoneMensile                  Float
  regimeFiscale                  RegimeFiscale
  stato                          StatoContratto @default(BOZZA)
  dataRegistrazioneAdE           DateTime?
  dataUltimoRinnovoRegistrazione DateTime?
  depositoImporto                Float
  depositoStato                  StatoDeposito  @default(NON_VERSATO)
  interessiLegaliMaturati        Float          @default(0)
  dataRestituzioneDeposito       DateTime?
  /**
   * Motivazione della contestazione (es. danni riscontrati), impostata quando depositoStato passa a IN_CONTESTAZIONE.
   */
  depositoNote                   String?
  createdAt                      DateTime       @default(now())

  pagamenti Pagamento[]
  documenti Documento[]
  checklist ChecklistImmobile[]
  inviti    InvitoInquilino[]
  relazioni RelazioneImmobilePrivato[]

  @@index([immobileId])
  @@index([proprietarioId])
  @@index([inquilinoId])
  @@index([agenziaId])
  @@index([stato])
}

model Pagamento {
  id          String    @id @default(cuid())
  contrattoId String
  contratto   Contratto @relation(fields: [contrattoId], references: [id], onDelete: Cascade)

  importo         Float
  dataScadenza    DateTime
  dataPagamento   DateTime?
  /**
   * Data prevista di accredito al proprietario: +2 giorni lavorativi dal pagamento, simulazione "banca a banca".
   */
  dataAccredito   DateTime?
  stato           StatoPagamento @default(PROGRAMMATO)
  metodoPagamento String?

  @@index([contrattoId])
  @@index([stato, dataScadenza])
}

model Utenza {
  id         String   @id @default(cuid())
  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)

  tipo            TipoUtenza
  fornitore       String
  stato           StatoUtenza @default(DA_ATTIVARE)
  dataAttivazione DateTime?

  /// POD (elettricità) o PDR (gas): richiesti per attivazione/voltura, opzionali finché non disponibili.
  codicePod          String?
  codicePdr          String?
  /// Fornitore precedente, per i casi di subentro/voltura.
  fornitoreUscente   String?
  /// Solo se diverso dall'indirizzo dell'immobile.
  indirizzoFornitura String?

  @@index([immobileId])
}

model Assicurazione {
  id         String   @id @default(cuid())
  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)

  tipo             String
  fornitore        String
  premioAnnuale    Float
  stato            StatoAssicurazione @default(ATTIVA)
  dataScadenza     DateTime
  commissioneLoqo  Float
  /// Valore indicativo ai fini di quotazione: distinto da Immobile.valoreStimato (valore di
  /// mercato), può differire legittimamente dal valore da assicurare (es. costo di ricostruzione).
  valoreAssicurato Float?

  @@index([immobileId])
}

model ChecklistImmobile {
  id          String    @id @default(cuid())
  contrattoId String
  contratto   Contratto @relation(fields: [contrattoId], references: [id], onDelete: Cascade)

  tipo                TipoChecklist
  fotoUrls            String[]
  firmaInquilino      Boolean       @default(false)
  firmaInquilinoAt    DateTime?
  firmaProprietario   Boolean       @default(false)
  firmaProprietarioAt DateTime?
  note                String?
  dataCompilazione    DateTime      @default(now())

  /// Letture contatori a verbale ingresso/uscita: utili per voltura utenze e contestazioni consumi.
  letturaLuce  Float?
  letturaGas   Float?
  letturaAcqua Float?

  @@index([contrattoId])
}

model Segnalazione {
  id                      String                 @id @default(cuid())
  titolo                  String
  descrizione             String
  categoria               CategoriaSegnalazione?
  categoriaIntervento     CategoriaIntervento?
  priorita                String
  stato                   StatoSegnalazione      @default(APERTA)
  /// Stesso pattern di ChecklistImmobile.fotoUrls: mock (nessun upload reale), coerente con
  /// l'unico altro punto della piattaforma che oggi allega foto.
  fotoUrls                String[]               @default([])
  fasciaOrariaDisponibile String?

  creatoDaUserId String
  creatoDa       User   @relation("SegnalazioniCreate", fields: [creatoDaUserId], references: [id], onDelete: Cascade)

  immobileId String
  immobile   Immobile @relation(fields: [immobileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  destinatari         SegnalazioneDestinatario[]
  risposte            SegnalazioneRisposta[]
  richiestaPreventivo RichiestaPreventivo?

  @@index([immobileId])
  @@index([creatoDaUserId])
  @@index([stato])
}

model SegnalazioneDestinatario {
  id             String       @id @default(cuid())
  segnalazioneId String
  segnalazione   Segnalazione @relation(fields: [segnalazioneId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  letto       Boolean   @default(false)
  dataLettura DateTime?

  @@unique([segnalazioneId, userId])
  @@index([userId])
}

model SegnalazioneRisposta {
  id             String       @id @default(cuid())
  segnalazioneId String
  segnalazione   Segnalazione @relation(fields: [segnalazioneId], references: [id], onDelete: Cascade)
  autoreUserId   String
  autore         User         @relation(fields: [autoreUserId], references: [id], onDelete: Cascade)

  testo     String
  createdAt DateTime @default(now())

  @@index([segnalazioneId])
}

model Partner {
  id                String              @id @default(cuid())
  nome              String
  categoria         CategoriaIntervento
  zonaCopertura     String
  telefono          String
  email             String
  contattoReferente String
  attivo            Boolean             @default(true)
  /// Per fatturazione/contrattualistica col partner.
  piva              String?
  pec               String?
  /**
   * Percentuale o importo fisso stimato per lead: solo per uso interno/admin, non esposto agli altri ruoli.
   */
  commissioneMedia  Float?
  createdAt         DateTime            @default(now())

  richiestePreventivo RichiestaPreventivo[]

  @@index([categoria, attivo])
}

model RichiestaPreventivo {
  id String @id @default(cuid())

  segnalazioneId String       @unique
  segnalazione   Segnalazione @relation(fields: [segnalazioneId], references: [id], onDelete: Cascade)
  partnerId      String
  partner        Partner      @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  richiedenteUserId String
  richiedente       User   @relation(fields: [richiedenteUserId], references: [id], onDelete: Cascade)

  stato     StatoRichiestaPreventivo @default(INVIATA)
  note      String?
  createdAt DateTime                 @default(now())

  @@index([partnerId])
  @@index([richiedenteUserId])
  @@index([stato])
}

model ComunicazioneCondominiale {
  id               String     @id @default(cuid())
  condominioId     String
  condominio       Condominio @relation(fields: [condominioId], references: [id], onDelete: Cascade)
  amministratoreId String

  titolo    String
  testo     String
  createdAt DateTime @default(now())

  letture LetturaComunicazione[]

  @@index([condominioId])
}

model LetturaComunicazione {
  id              String                    @id @default(cuid())
  comunicazioneId String
  comunicazione   ComunicazioneCondominiale @relation(fields: [comunicazioneId], references: [id], onDelete: Cascade)
  userId          String
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lettoAt         DateTime                  @default(now())

  @@unique([comunicazioneId, userId])
  @@index([userId])
}

model InvitoInquilino {
  id          String    @id @default(cuid())
  token       String    @unique
  inquilinoId String
  inquilino   Privato   @relation(fields: [inquilinoId], references: [id], onDelete: Cascade)
  contrattoId String
  contratto   Contratto @relation(fields: [contrattoId], references: [id], onDelete: Cascade)

  email     String
  scadenza  DateTime
  usatoAt   DateTime?
  createdAt DateTime  @default(now())

  @@index([inquilinoId])
  @@index([contrattoId])
}

model Documento {
  id           String      @id @default(cuid())
  contrattoId  String?
  contratto    Contratto?  @relation(fields: [contrattoId], references: [id], onDelete: Cascade)
  immobileId   String?
  immobile     Immobile?   @relation(fields: [immobileId], references: [id], onDelete: Cascade)
  condominioId String?
  condominio   Condominio? @relation(fields: [condominioId], references: [id], onDelete: Cascade)

  caricatoDaUserId String
  caricatoDa       User   @relation("DocumentiCaricati", fields: [caricatoDaUserId], references: [id], onDelete: Cascade)

  nome                     String
  url                      String
  /// Tecnico: MIME type rilevato dal file caricato (es. "application/pdf"), non una
  /// classificazione business — vedi `categoria` per quella.
  tipo                     String
  uploadedAt               DateTime  @default(now())
  /// Se valorizzata, il documento (record + file su Blob) viene eliminato la prima volta che
  /// qualcuno legge la lista documenti dopo questa data (eliminazione lazy, niente cron: vedi
  /// lib/documenti/eliminaDocumentiScaduti.ts). Meccanismo tecnico di pulizia storage, distinto
  /// da `scadenzaDocumento` (scadenza reale del documento, per lo scadenzario).
  scadenzaAutoEliminazione DateTime?

  /// Classificazione business del documento (contratto, APE, planimetria, ...), scelta dall'utente.
  categoria         CategoriaDocumento?
  /// Scadenza reale del documento (es. carta d'identità, APE, polizza), per alimentare lo scadenzario.
  scadenzaDocumento DateTime?
  nota              String?

  condivisioni DocumentoCondivisione[]

  @@index([contrattoId])
  @@index([immobileId])
  @@index([condominioId])
  @@index([caricatoDaUserId])
}

/// Con chi è condiviso un Documento oltre a chi lo ha caricato: stesso pattern di
/// SegnalazioneDestinatario, con l'aggiunta di `ruolo` (denormalizzato al momento della
/// condivisione) e del tracciamento separato lettura/download.
model DocumentoCondivisione {
  id          String    @id @default(cuid())
  documentoId String
  documento   Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruolo       Role

  letto            Boolean   @default(false)
  dataLettura      DateTime?
  scaricato        Boolean   @default(false)
  dataScaricamento DateTime?

  @@unique([documentoId, userId])
  @@index([userId])
}

/// Bacheca unica per raccogliere segnalazioni/suggerimenti rivolti allo sviluppatore, letta da
/// TUTTI gli utenti di TUTTI i portali (memoria universale, coerente con la natura demo del
/// prodotto): non è scoperta per immobile/ruolo come Segnalazione, è visibile globalmente.
model NotaSviluppatore {
  id      String               @id @default(cuid())
  testo   String
  tipo    TipoNotaSviluppatore @default(SUGGERIMENTO)
  risolta Boolean              @default(false)

  createdAt DateTime @default(now())

  autoreUserId String
  autore       User   @relation(fields: [autoreUserId], references: [id], onDelete: Cascade)

  @@index([autoreUserId])
  @@index([createdAt])
}
